{
	"modules-left": ["hyprland/workspaces"],

	"hyprland/workspaces": {
		"persistent-workspaces": {
			"*": 10
		}
	},
	"modules-center": ["clock"],
	"modules-right": ["network", "battery"],

	"clock": {
		"format": "{:%H:%M}",
		"tooltip-format": "{:%A, %B %d %Y}"
	},

	"network": {
		"format-wifi": " {signalStrength}%",
		"format-disconnected": "dc"
	}
}
